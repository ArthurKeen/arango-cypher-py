# ─── ArangoDB Connection ─────────────────────────────────────────────
# URL of the ArangoDB coordinator (http or https)
ARANGO_URL=http://localhost:8529
# ARANGO_URL=https://your-instance.arangocloud.com/

# Default database to connect to
ARANGO_DB=_system

# Credentials
ARANGO_USER=root
ARANGO_PASS=

# ─── LLM Providers (for NL→Cypher / NL→AQL) ────────────────────────
# At least one of these is required for natural-language query generation.

# OpenRouter (recommended for multi-model access)
# OPENROUTER_API_KEY=sk-or-v1-...

# OpenAI (direct)
# OPENAI_API_KEY=sk-...

# Anthropic (direct). Default model is claude-sonnet-4-5; override with
# ANTHROPIC_MODEL if you want e.g. claude-haiku-4-5 for lower cost.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Select which provider get_llm_provider() returns when multiple keys are set.
# One of: openrouter | openai | anthropic. Defaults to the first key found.
# LLM_PROVIDER=openai

# ─── Server ─────────────────────────────────────────────────────────
# Port for the FastAPI backend (default: 8000)
# PORT=8000

# Base path for the FastAPI app when reverse-proxied under a sub-path
# (e.g. behind the ArangoDB platform router). Leave unset in standalone
# dev. Example: ROOT_PATH=/byoc/arango-cypher
# ROOT_PATH=

# ─── Service limits & CORS ──────────────────────────────────────────
# Per-minute token bucket for NL→Cypher / NL→AQL endpoints. Keyed by
# Authorization header (or client IP for anonymous callers). Default 10.
# NL_RATE_LIMIT_PER_MINUTE=10

# How long an idle session may live before eviction. After this many
# seconds without activity, the session's python-arango client is
# closed and the token is invalidated (401 on next use). Default 1800.
# SESSION_TTL_SECONDS=1800

# Upper bound on the in-memory session table; oldest-by-last_used is
# evicted when the cap is reached. Default 100. Raise for multi-tenant
# deployments with many concurrent UI users.
# MAX_SESSIONS=100

# Comma-separated list of allowed CORS origins, or `*` for any. When
# `*` is used together with credentialed requests, browsers will block
# the fetch — pin an explicit list for production deployments.
# Default: *
# CORS_ALLOWED_ORIGINS=https://workbench.example.com,https://app.example.com

# ─── Heuristic schema mapping (fallback) ────────────────────────────
# When the arangodb-schema-analyzer package is not available the
# service refuses to start unless this opt-out is set. Intended for
# local exploration only — heuristic mappings miss many edge cases
# that can produce incorrect AQL. Default: unset (refuse).
# ARANGO_CYPHER_ALLOW_HEURISTIC=1
